// IBKeyer OpenCL Kernel
// Stub implementation — falls back to CPU processing
// (Can be expanded with a full OpenCL kernel in the future)

#ifdef _WIN32
#include <windows.h>
#else
#include <dlfcn.h>
#include <pthread.h>
#endif
#include <cstring>
#include <cmath>
#include <stdio.h>

const char *KernelSource =
"__kernel void IBKeyerKernel(\n"
"    int p_Width, int p_Height,\n"
"    int p_ScreenColor, int p_UseScreenInput,\n"
"    float p_PickR, float p_PickG, float p_PickB,\n"
"    float p_Bias, float p_Limit,\n"
"    float p_RespillR, float p_RespillG, float p_RespillB,\n"
"    int p_Premultiply, int p_NearGreyExtract, float p_NearGreyAmount,\n"
"    __global const float* p_Input,\n"
"    __global const float* p_Screen,\n"
"    __global float* p_Output)\n"
"{\n"
"    const int x = get_global_id(0);\n"
"    const int y = get_global_id(1);\n"
"\n"
"    if ((x < p_Width) && (y < p_Height))\n"
"    {\n"
"        const int idx = ((y * p_Width) + x) * 4;\n"
"\n"
"        float srcR = p_Input[idx + 0];\n"
"        float srcG = p_Input[idx + 1];\n"
"        float srcB = p_Input[idx + 2];\n"
"\n"
"        float scrR, scrG, scrB;\n"
"        if (p_UseScreenInput != 0) {\n"
"            scrR = p_Screen[idx + 0];\n"
"            scrG = p_Screen[idx + 1];\n"
"            scrB = p_Screen[idx + 2];\n"
"        } else {\n"
"            scrR = p_PickR; scrG = p_PickG; scrB = p_PickB;\n"
"        }\n"
"\n"
"        // Reorder channels\n"
"        float c0s, c1s, c2s, c0r, c1r, c2r;\n"
"        if (p_ScreenColor == 0) {\n"
"            c0s = scrR; c1s = scrG; c2s = scrB;\n"
"            c0r = srcR; c1r = srcG; c2r = srcB;\n"
"        } else if (p_ScreenColor == 1) {\n"
"            c0s = scrG; c1s = scrR; c2s = scrB;\n"
"            c0r = srcG; c1r = srcR; c2r = srcB;\n"
"        } else {\n"
"            c0s = scrB; c1s = scrR; c2s = scrG;\n"
"            c0r = srcB; c1r = srcR; c2r = srcG;\n"
"        }\n"
"\n"
"        float dSrc = c0r - (c1r * p_Bias + c2r * (1.0f - p_Bias)) * p_Limit;\n"
"        float dScr = c0s - (c1s * p_Bias + c2s * (1.0f - p_Bias)) * p_Limit;\n"
"        float norm = (fabs(dScr) > 1e-8f) ? dSrc / dScr : 0.0f;\n"
"\n"
"        float spillMul = max(0.0f, norm);\n"
"        float ssR = srcR - spillMul * scrR;\n"
"        float ssG = srcG - spillMul * scrG;\n"
"        float ssB = srcB - spillMul * scrB;\n"
"\n"
"        float alpha = clamp(1.0f - norm, 0.0f, 1.0f);\n"
"\n"
"        if (p_NearGreyExtract != 0) {\n"
"            float divR = (fabs(srcR) > 1e-8f) ? ssR / srcR : 0.0f;\n"
"            float divG = (fabs(srcG) > 1e-8f) ? ssG / srcG : 0.0f;\n"
"            float divB = (fabs(srcB) > 1e-8f) ? ssB / srcB : 0.0f;\n"
"            float dc0, dc1, dc2;\n"
"            if (p_ScreenColor == 0)      { dc0 = divR; dc1 = divG; dc2 = divB; }\n"
"            else if (p_ScreenColor == 1) { dc0 = divG; dc1 = divR; dc2 = divB; }\n"
"            else                         { dc0 = divB; dc1 = divR; dc2 = divG; }\n"
"            float mx = max(dc0, max(dc1, dc2));\n"
"            float comp = (mx == dc1) ? dc1 : dc2;\n"
"            float ngeA = clamp(dc0 * (1.0f - p_NearGreyAmount) + comp * p_NearGreyAmount, 0.0f, 1.0f);\n"
"            alpha = ngeA + alpha - ngeA * alpha;\n"
"        }\n"
"\n"
"        float outR = ssR;\n"
"        float outG = ssG;\n"
"        float outB = ssB;\n"
"\n"
"        float rspMul = max(0.0f, dScr * norm);\n"
"        outR += rspMul * p_RespillR;\n"
"        outG += rspMul * p_RespillG;\n"
"        outB += rspMul * p_RespillB;\n"
"\n"
"        if (p_Premultiply != 0) {\n"
"            outR *= alpha;\n"
"            outG *= alpha;\n"
"            outB *= alpha;\n"
"        }\n"
"\n"
"        p_Output[idx + 0] = outR;\n"
"        p_Output[idx + 1] = outG;\n"
"        p_Output[idx + 2] = outB;\n"
"        p_Output[idx + 3] = alpha;\n"
"    }\n"
"}\n";

class Locker
{
public:
    Locker()
    {
#ifdef _WIN32
        InitializeCriticalSection(&CriticalSection);
#else
        pthread_mutex_init(&mutex, NULL);
#endif
    }

    ~Locker()
    {
#ifdef _WIN32
        DeleteCriticalSection(&CriticalSection);
#else
        pthread_mutex_destroy(&mutex);
#endif
    }

    void Lock()
    {
#ifdef _WIN32
        EnterCriticalSection(&CriticalSection);
#else
        pthread_mutex_lock(&mutex);
#endif
    }

    void Unlock()
    {
#ifdef _WIN32
        LeaveCriticalSection(&CriticalSection);
#else
        pthread_mutex_unlock(&mutex);
#endif
    }

private:
#ifdef _WIN32
    CRITICAL_SECTION CriticalSection;
#else
    pthread_mutex_t mutex;
#endif
};

void RunOpenCLKernel(void* p_CmdQ, int p_Width, int p_Height,
                     int p_ScreenColor, int p_UseScreenInput,
                     float p_PickR, float p_PickG, float p_PickB,
                     float p_Bias, float p_Limit,
                     float p_RespillR, float p_RespillG, float p_RespillB,
                     int p_Premultiply, int p_NearGreyExtract, float p_NearGreyAmount,
                     const float* p_Input, const float* p_Screen, float* p_Output)
{
    // Stub — OpenCL not fully implemented, CPU fallback will be used
    printf("IBKeyer: OpenCL kernel not fully implemented — using CPU fallback\n");
}
